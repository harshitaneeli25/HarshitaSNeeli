<web-app>

<servlet>
    <servlet-name>AddReservation</servlet-name>
    <servlet-class>servlet.AddReservationServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>AddReservation</servlet-name>
    <url-pattern>/addReservation</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>UpdateReservation</servlet-name>
    <servlet-class>servlet.UpdateReservationServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>UpdateReservation</servlet-name>
    <url-pattern>/updateReservation</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeleteReservation</servlet-name>
    <servlet-class>servlet.DeleteReservationServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>DeleteReservation</servlet-name>
    <url-pattern>/deleteReservation</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DisplayReservations</servlet-name>
    <servlet-class>servlet.DisplayReservationsServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>DisplayReservations</servlet-name>
    <url-pattern>/displayReservations</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ReportCriteria</servlet-name>
    <servlet-class>servlet.ReportCriteriaServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ReportCriteria</servlet-name>
    <url-pattern>/reportCriteria</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ReportServlet</servlet-name>
    <servlet-class>servlet.ReportServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ReportServlet</servlet-name>
    <url-pattern>/report</url-pattern>
</servlet-mapping>

</web-app>